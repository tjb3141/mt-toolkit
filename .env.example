# Copy to .env on the Pi (and locally if you want to run prod build).
# Pi reads this via systemd EnvironmentFile.

# Public — shipped to the browser bundle
EXPO_PUBLIC_SUPABASE_URL=https://ouxfgdbpdkykovbsifbr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never bundled
SUPABASE_SERVICE_KEY=your-service-role-key-here
ADMIN_SECRET=your-admin-password-here
